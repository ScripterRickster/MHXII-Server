# Example environment variables for local testing and Render
# Copy to .env and fill values before running locally

# Either set MONGO_URI directly (mongodb+srv://... or mongodb://...)
MONGO_URI=

# Or provide user/pass/host and let server.py build the URI
MONGO_USER=
MONGO_PASS=
MONGO_HOST=mhxii.qi2wpez.mongodb.net
MONGO_DB=testdb

# Raspberry Pi URL for robot control (default: http://192.168.1.100:5000)
PI_URL=http://192.168.1.100:5000

# Port used locally; Render supplies $PORT automatically
PORT=8000
